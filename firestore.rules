rules_version = '2';

// Firestore security rules v2 — project: pangeya-essay
// Paste into: https://console.firebase.google.com/project/pangeya-essay/firestore/rules
//
// v2 (2026-07-16): the project's web API key is restricted and cannot call
// Firebase Auth (Identity Toolkit rejects it), so owner-token moderation is
// impossible without console access to the key. Model changed to
// "hidden-only moderation":
//   - anyone may CREATE (publish) — that is the product, no sign-up to write
//   - anyone may flip ONLY the `hidden` flag — powers /admin Hide/Show;
//     reversible by design, so vandalism is undoable
//   - NOBODY may edit other fields or DELETE — content is tamper-proof
//   - likes on advice may only increase
// Existing apps (Writing Lab, Speaking Lab) keep exactly today's access.
//
// Collections audited 2026-07-15: essays, giftMessages (Writing Lab);
// speakingQuestions, speakingAnswers (Speaking Lab); vocab, comments (old
// Writing Lab builds); articles, advice, advice_comments (news community).

service cloud.firestore {
  match /databases/{database}/documents {

    function hiddenOnly() {
      return request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['hidden'])
             && request.resource.data.hidden is bool;
    }

    // ================= existing apps — UNCHANGED (public by product design) =====
    match /essays/{id}       { allow read, write: if true; }
    match /giftMessages/{id} { allow read, write: if true; }
    match /speakingQuestions/{id} { allow read, write: if true; }
    match /speakingAnswers/{id}   { allow read, write: if true; }
    match /vocab/{id}    { allow read, write: if true; }
    match /comments/{id} { allow read, write: if true; }

    // ================= news community =========================================

    match /articles/{id} {
      allow read: if true;
      allow create: if request.resource.data.title is string
                    && request.resource.data.title.size() >= 5
                    && request.resource.data.title.size() <= 200
                    && request.resource.data.body is string
                    && request.resource.data.body.size() >= 200
                    && request.resource.data.body.size() <= 40000
                    && request.resource.data.author is string
                    && request.resource.data.author.size() <= 80
                    && (!('hidden' in request.resource.data)
                        || request.resource.data.hidden == false);
      allow update: if hiddenOnly();
      allow delete: if false;
    }

    match /advice/{id} {
      allow read: if true;
      allow create: if request.resource.data.text is string
                    && request.resource.data.text.size() >= 10
                    && request.resource.data.text.size() <= 2000
                    && (!('hidden' in request.resource.data)
                        || request.resource.data.hidden == false);
      allow update: if hiddenOnly()
                    || (request.resource.data.diff(resource.data)
                          .affectedKeys().hasOnly(['likes'])
                        && request.resource.data.likes is int
                        && request.resource.data.likes > resource.data.likes);
      allow delete: if false;
    }

    match /advice_comments/{id} {
      allow read: if true;
      allow create: if request.resource.data.text is string
                    && request.resource.data.text.size() >= 2
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.author is string
                    && request.resource.data.author.size() <= 80;
      allow update: if hiddenOnly();
      allow delete: if false;
    }

    // ================= anything new: closed by default =========================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
